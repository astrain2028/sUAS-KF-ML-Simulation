import numpy as np
import matplotlib.pyplot as plt
from matplotlib.widgets import Button
from matplotlib.patches import Rectangle, Polygon, Wedge, Circle
from matplotlib.transforms import Affine2D
import torch
import torch.nn as nn

np.random.seed(42)
torch.manual_seed(42)

# Parameters
DT = 0.05
WHEEL_RADIUS = 0.05
TRACK_WIDTH = 0.40

ENCODER_NOISE_STD = 0.003
GYRO_NOISE_STD = 0.01

ENCODER_FAULT_BIAS = 0.10
GYRO_FAULT_BIAS = 0.25

STATE_DIM = 5
MEAS_DIM = 5
FAULT_DIM = 5

TRAIN_RUNS = 40
TRAIN_STEPS = 180
LIVE_STEPS_MAX = 400

# Robot model
# state = [x, y, theta, v, omega]
# meas  = [enc_fl, enc_fr, enc_rl, enc_rr, gyro_z]
def wrap_to_pi(angle):
    return (angle + np.pi) % (2 * np.pi) - np.pi


def propagate_state(state):
    x, y, theta, v, omega = state
    x = x + v * np.cos(theta) * DT
    y = y + v * np.sin(theta) * DT
    theta = wrap_to_pi(theta + omega * DT)
    return np.array([x, y, theta, v, omega], dtype=float)


def command_spath(t):
    v = 0.85 + 0.12 * np.sin(0.15 * t)
    omega = 0.90 * np.sin(0.35 * t)
    return v, omega


def wheel_rates_from_body(v, omega):
    v_r = v + 0.5 * TRACK_WIDTH * omega
    v_l = v - 0.5 * TRACK_WIDTH * omega
    phi_dot_r = v_r / WHEEL_RADIUS
    phi_dot_l = v_l / WHEEL_RADIUS
    return phi_dot_l, phi_dot_r


def measurement_model(state):
    _, _, _, v, omega = state
    phi_dot_l, phi_dot_r = wheel_rates_from_body(v, omega)

    dphi_l = phi_dot_l * DT
    dphi_r = phi_dot_r * DT

    return np.array([dphi_l, dphi_r, dphi_l, dphi_r, omega], dtype=float)


def add_noise(z):
    std = np.array([ENCODER_NOISE_STD] * 4 + [GYRO_NOISE_STD], dtype=float)
    return z + np.random.randn(5) * std


def apply_faults(z, fault_flags):
    z_faulty = z.copy()
    for i in range(4):
        if fault_flags[i]:
            z_faulty[i] += ENCODER_FAULT_BIAS
    if fault_flags[4]:
        z_faulty[4] += GYRO_FAULT_BIAS
    return z_faulty


# Simulation data generation
def simulate_spath_trial(num_steps):
    states = np.zeros((num_steps, STATE_DIM))
    measurements = np.zeros((num_steps, MEAS_DIM))

    state = np.array([0.0, 0.0, 0.0, 0.8, 0.0], dtype=float)

    for k in range(num_steps):
        t = k * DT
        v_cmd, omega_cmd = command_spath(t)
        state[3] = v_cmd
        state[4] = omega_cmd
        state = propagate_state(state)

        z = add_noise(measurement_model(state))
        states[k] = state
        measurements[k] = z

    return states, measurements


def simulate_random_trial(num_steps, fault_prob=0.0):
    states = np.zeros((num_steps, STATE_DIM))
    measurements = np.zeros((num_steps, MEAS_DIM))
    fault_flags_all = np.zeros((num_steps, FAULT_DIM))

    state = np.array([
        np.random.uniform(-1, 1),
        np.random.uniform(-1, 1),
        np.random.uniform(-np.pi, np.pi),
        0.0,
        0.0
    ], dtype=float)

    v_cmd = np.random.uniform(0.2, 1.0)
    omega_cmd = np.random.uniform(-1.5, 1.5)
    next_switch = 0.0

    for k in range(num_steps):
        t = k * DT

        if t >= next_switch:
            v_cmd = np.random.uniform(0.2, 1.2)
            omega_cmd = np.random.uniform(-1.8, 1.8)
            next_switch = t + np.random.uniform(0.8, 2.0)

        state[3] = np.clip(v_cmd + 0.03 * np.random.randn(), 0.0, 1.5)
        state[4] = np.clip(omega_cmd + 0.06 * np.random.randn(), -2.0, 2.0)
        state = propagate_state(state)

        z = add_noise(measurement_model(state))
        fault_flags = (np.random.rand(5) < fault_prob).astype(float)
        z = apply_faults(z, fault_flags)

        states[k] = state
        measurements[k] = z
        fault_flags_all[k] = fault_flags

    return states, measurements, fault_flags_all


def build_baseline_dataset(num_runs, num_steps):
    X_list = []
    Y_list = []

    for i in range(num_runs):
        if i < max(1, num_runs // 5):
            states, measurements = simulate_spath_trial(num_steps)
        else:
            states, measurements, _ = simulate_random_trial(num_steps, fault_prob=0.0)

        X_list.append(states)
        Y_list.append(measurements)

    return np.vstack(X_list), np.vstack(Y_list)


def build_fault_dataset(num_runs, num_steps, fault_prob=0.08):
    X_list = []
    Y_list = []

    for _ in range(num_runs):
        states, faulty_measurements, fault_flags_all = simulate_random_trial(
            num_steps, fault_prob=fault_prob
        )
        X_aug = np.hstack([states, fault_flags_all])
        X_list.append(X_aug)
        Y_list.append(faulty_measurements)

    return np.vstack(X_list), np.vstack(Y_list)


# Neural network
class Net(nn.Module):
    def __init__(self, input_dim, output_dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, 64),
            nn.ReLU(),
            nn.Linear(64, 64),
            nn.ReLU(),
            nn.Linear(64, output_dim)
        )

    def forward(self, x):
        return self.net(x)


def standardize_xy(X, Y):
    x_mean = X.mean(axis=0, keepdims=True)
    x_std = X.std(axis=0, keepdims=True) + 1e-8
    y_mean = Y.mean(axis=0, keepdims=True)
    y_std = Y.std(axis=0, keepdims=True) + 1e-8

    Xn = (X - x_mean) / x_std
    Yn = (Y - y_mean) / y_std

    stats = {
        "x_mean": x_mean,
        "x_std": x_std,
        "y_mean": y_mean,
        "y_std": y_std,
    }
    return Xn, Yn, stats


def train_model(X, Y, input_dim, output_dim, epochs=80):
    Xn, Yn, stats = standardize_xy(X, Y)

    X_tensor = torch.tensor(Xn, dtype=torch.float32)
    Y_tensor = torch.tensor(Yn, dtype=torch.float32)

    model = Net(input_dim, output_dim)
    optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)
    loss_fn = nn.MSELoss()

    loss_history = []

    for _ in range(epochs):
        optimizer.zero_grad()
        pred = model(X_tensor)
        loss = loss_fn(pred, Y_tensor)
        loss.backward()
        optimizer.step()
        loss_history.append(loss.item())

    return model, stats, loss_history


def predict_model(model, stats, X):
    Xn = (X - stats["x_mean"]) / stats["x_std"]
    X_tensor = torch.tensor(Xn, dtype=torch.float32)

    with torch.no_grad():
        Yn_pred = model(X_tensor).cpu().numpy()

    Y_pred = Yn_pred * stats["y_std"] + stats["y_mean"]
    return Y_pred


