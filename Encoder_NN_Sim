# Drawing helpers
def rot2d(theta):
    c = np.cos(theta)
    s = np.sin(theta)
    return np.array([[c, -s], [s, c]])


def rect_polygon(cx, cy, length, width, heading):
    hl = length / 2.0
    hw = width / 2.0
    corners = np.array([
        [ hl,  hw],
        [ hl, -hw],
        [-hl, -hw],
        [-hl,  hw],
    ])
    R = rot2d(heading)
    return (R @ corners.T).T + np.array([cx, cy])


