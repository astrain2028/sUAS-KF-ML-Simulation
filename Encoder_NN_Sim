)

# Buttons
ax_run_spath = fig.add_axes([0.72, 0.82, 0.20, 0.055])
ax_run_mc = fig.add_axes([0.72, 0.74, 0.20, 0.055])
ax_pause = fig.add_axes([0.72, 0.66, 0.20, 0.055])
