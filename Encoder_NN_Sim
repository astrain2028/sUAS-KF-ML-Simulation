# Update display
def update_robot():
    x, y, theta, v, omega = sim["state"]

    transform = Affine2D().rotate(theta).translate(x, y) + ax.transData
    for patch in [flag_base, stripe_top, stripe_bottom, c_outer, sun]:
        patch.set_transform(transform)

    R = rot2d(theta)
    for poly, (ox, oy) in zip(wheel_patches, wheel_offsets):
        wx, wy = (R @ np.array([ox, oy])) + np.array([x, y])
        poly.set_xy(rect_polygon(wx, wy, wheel_length, wheel_width, theta))

    nose = np.array([x, y]) + 0.45 * np.array([np.cos(theta), np.sin(theta)])
    heading_line.set_data([x, nose[0]], [y, nose[1]])
    path_line.set_data(sim["path_x"], sim["path_y"])

    status_text.set_text(
        f"running:          {sim['running']}\n"
        f"mode:             {sim['mode']}\n"
        f"step:             {sim['step']}\n"
        f"time:             {sim['time']:.2f}\n"
        f"baseline trained: {sim['trained_baseline']}\n"
        f"fault trained:    {sim['trained_fault']}\n"
        f"x:                {x: .3f}\n"
        f"y:                {y: .3f}\n"
        f"theta:            {theta: .3f}\n"
        f"v:                {v: .3f}\n"
        f"omega:            {omega: .3f}\n"
        f"base res norm:    {sim['latest_base_res']: .4f}\n"
        f"fault res norm:   {sim['latest_fault_res']: .4f}"
    )

    fig.canvas.draw_idle()

# Button callbacks
def start_spath_mode():
    sim["mode"] = "spath"
    sim["running"] = True
    update_robot()

def start_mc_mode():
    sim["mode"] = "mc"
    sim["running"] = True
    update_robot()

def on_run_spath(event):
    start_spath_mode()

def on_run_mc(event):
    start_mc_mode()

def on_pause(event):
    sim["running"] = False
    update_robot()

def on_train_baseline(event):
    print("Building baseline dataset...")
    X_base, Y_base = build_baseline_dataset(TRAIN_RUNS, TRAIN_STEPS)

    print("Training baseline model: state -> healthy measurements")
    model, stats, loss_history = train_model(
        X_base, Y_base,
        input_dim=5,
        output_dim=5,
        epochs=80
    )

    sim["baseline_model"] = model
    sim["baseline_stats"] = stats
    sim["baseline_loss"] = loss_history
    sim["trained_baseline"] = True
    print("Baseline training complete.")
    update_robot()

def on_train_fault(event):
    print("Building fault dataset...")
    X_fault, Y_fault = build_fault_dataset(TRAIN_RUNS, TRAIN_STEPS, fault_prob=0.08)

    print("Training fault-aware model: [state + real faults] -> faulty measurements")
    model, stats, loss_history = train_model(
        X_fault, Y_fault,
        input_dim=10,
        output_dim=5,
        epochs=80
    )

    sim["fault_model"] = model
    sim["fault_stats"] = stats
    sim["fault_loss"] = loss_history
    sim["trained_fault"] = True
    print("Fault model training complete.")
    update_robot()

def on_reset(event):
    sim["running"] = False
    sim["step"] = 0
    sim["time"] = 0.0
    sim["mode"] = "spath"
    sim["state"] = np.array([0.0, 0.0, 0.0, 0.8, 0.0], dtype=float)
    sim["path_x"] = [0.0]
    sim["path_y"] = [0.0]
    sim["latest_base_res"] = np.nan
    sim["latest_fault_res"] = np.nan
    sim["mc_v_cmd"] = 0.8
    sim["mc_omega_cmd"] = 0.0
    sim["mc_next_switch"] = 0.0
    update_robot()

btn_run_spath.on_clicked(on_run_spath)
btn_run_mc.on_clicked(on_run_mc)
btn_pause.on_clicked(on_pause)
btn_train_base.on_clicked(on_train_baseline)
btn_train_fault.on_clicked(on_train_fault)
btn_reset.on_clicked(on_reset)

# Animation loop
def step():
    if not sim["running"]:
        return

    if sim["step"] >= LIVE_STEPS_MAX:
        sim["running"] = False
        update_robot()
        return

    t = sim["time"]

    if sim["mode"] == "spath":
        v_cmd, omega_cmd = command_spath(t)

    else:  # MC mode
        if t >= sim["mc_next_switch"]:
            sim["mc_v_cmd"] = np.random.uniform(0.2, 1.2)
            sim["mc_omega_cmd"] = np.random.uniform(-1.8, 1.8)
            sim["mc_next_switch"] = t + np.random.uniform(0.8, 2.0)

        v_cmd = np.clip(sim["mc_v_cmd"] + 0.03 * np.random.randn(), 0.0, 1.5)
        omega_cmd = np.clip(sim["mc_omega_cmd"] + 0.06 * np.random.randn(), -2.0, 2.0)

    sim["state"][3] = v_cmd
    sim["state"][4] = omega_cmd
    sim["state"] = propagate_state(sim["state"])

    z_clean = measurement_model(sim["state"])
    z_noisy = add_noise(z_clean)

    fault_vector = (np.random.rand(5) < 0.08).astype(float)
    z_measured = apply_faults(z_noisy, fault_vector)

    if sim["trained_baseline"]:
        z_pred_base = predict_model(
            sim["baseline_model"],
            sim["baseline_stats"],
            sim["state"][None, :]
        )[0]
        sim["latest_base_res"] = np.linalg.norm(z_measured - z_pred_base)

    if sim["trained_fault"]:
        X_aug = np.hstack([sim["state"], fault_vector])[None, :]
        z_pred_fault = predict_model(
            sim["fault_model"],
            sim["fault_stats"],
            X_aug
        )[0]
        sim["latest_fault_res"] = np.linalg.norm(z_measured - z_pred_fault)

    sim["path_x"].append(sim["state"][0])
    sim["path_y"].append(sim["state"][1])
    sim["time"] += DT
    sim["step"] += 1

    update_robot()

timer = fig.canvas.new_timer(interval=int(DT * 1000))
timer.add_callback(step)
timer.start()

update_robot()
plt.show()
